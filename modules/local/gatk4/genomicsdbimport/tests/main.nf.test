// Tests for local GATK4_GENOMICSDBIMPORT module
// Local module signature: (meta+vcf+tbi+dummy_interval, interval_file) — 2 inputs
nextflow_process {

    name "Test Process GATK4_GENOMICSDBIMPORT (local)"
    script "../main.nf"
    process "GATK4_GENOMICSDBIMPORT"

    tag "modules"
    tag "gatk4"
    tag "gatk4/genomicsdbimport"

    test("test_gatk4_genomicsdbimport_create_genomicsdb") {

        when {
            process {
                """
                // [meta, vcf, tbi, dummy_interval]
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/gvcf/test.genome.vcf.gz', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/gvcf/test.genome.vcf.gz.tbi', checkIfExists: true),
                    0
                ]
                // interval_file
                input[1] = file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.interval_list', checkIfExists: true)
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(
                    file(process.out.genomicsdb.get(0).get(1)).list().sort(),
                    process.out.findAll { key, val -> key.startsWith("versions") }
                ).match() }
            )
        }
    }

    test("test_gatk4_genomicsdbimport_stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/gvcf/test.genome.vcf.gz', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/gvcf/test.genome.vcf.gz.tbi', checkIfExists: true),
                    0
                ]
                input[1] = file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.interval_list', checkIfExists: true)
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(process.out).match() }
            )
        }
    }
}
