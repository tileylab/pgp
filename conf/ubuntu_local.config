/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Ubuntu local execution profile
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Recommended for a single Ubuntu server with roughly 16 CPU / 64 GB RAM.
----------------------------------------------------------------------------------------
*/

params {
    config_profile_name        = 'ubuntu_local'
    config_profile_description = 'Ubuntu local profile with conservative parallelism and enhanced diagnostics'
}

executor {
    name        = 'local'
    cpus        = 14
    memory      = '56 GB'
    queueSize   = 4
    pollInterval = '200 ms'
}

process {
    maxForks = 4

    withLabel:process_high {
        maxForks = 1
    }

    withName: FASTP {
        cpus   = 4
        memory = { 12.GB * task.attempt }
        time   = { 8.h * task.attempt }
    }

    withName: PICARD_MARKDUPLICATES {
        cpus   = 2
        memory = { 16.GB * task.attempt }
        time   = { 10.h * task.attempt }
    }

    withName: BWA_MEM {
        cpus   = 8
        memory = { 32.GB * task.attempt }
        time   = { 10.h * task.attempt }
    }
}

trace {
    fields = 'task_id,hash,native_id,process,tag,status,exit,attempt,cpus,memory,duration,realtime,%cpu,%mem,rss,vmem,workdir'
}
