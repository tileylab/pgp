/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per module options and publishing paths
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Available keys to override module options:
        ext.args   = Additional arguments appended to command in module.
        ext.args2  = Second set of arguments appended to command in module (multi-tool modules).
        ext.args3  = Third set of arguments appended to command in module (multi-tool modules).
        ext.prefix = File name prefix for output files.
----------------------------------------------------------------------------------------
*/

process {

    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].tokenize('_')[0].toLowerCase()}" },
        mode: params.publish_dir_mode,
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]

    withName: FASTQC {
        ext.args = '--quiet'
    }

    withName: 'MULTIQC' {
        ext.args   = { params.multiqc_title ? "--title \"$params.multiqc_title\"" : '' }
        publishDir = [
            path: { "${params.outdir}/multiqc" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName:FASTQC {
        cpus   = { 2     * task.attempt }
        memory = { 4.GB  * task.attempt }
        time   = { 6.h   * task.attempt }
    }
    
    withName: FASTP {
        cpus = 4
        memory = { 8.GB * task.attempt }
        time = { 6.h * task.attempt }
    }

    withName: PICARD_MARKDUPLICATES {
        cpus = 2
        memory = { task.attempt > 1 ? 16.GB : 12.GB }
        time = { 12.h * task.attempt }
    }

    withName: BBMAP_BBDUK {
        cpus = 4
        memory = { 4.GB * task.attempt }
    }

    withName: BWA_MEM {
        cpus = 8
        memory = { 24.GB * task.attempt }
        time = { 8.h * task.attempt }

        ext.args = { [
            '-R \"@RG\\tID:',
            "${meta.id}",
            '\\tSM:',
            "${meta.id}",
            '\\tLB:lib\\tPL:ILLUMINA\"'
        ].join('')}

        // Prevent samtools sort from over-allocating memory per thread on small hosts.
        ext.args2 = { '-m 1G' }
    }

    withName: BWA_INDEX {
        cpus = 1
        memory = { 1.GB * task.attempt }
    }

    withName: SAMTOOLS_VIEW {
        ext.args = { [
            '-b',
            '-q 20',
            '-f 2',
            '-F 4'].join(' ') }

        ext.prefix = { [
            "${meta.id}",
            ".q20"].join('') }
    }

    withName: PICARD_MARKDUPLICATES {
        ext.args = { [
            '--CREATE_INDEX',
            '--MAX_RECORDS_IN_RAM 100000',
            '--MAX_FILE_HANDLES_FOR_READ_ENDS_MAP 4000',
            '--MAX_SEQUENCES_FOR_DISK_READ_ENDS_MAP 20000',
            '--SORTING_COLLECTION_SIZE_RATIO 0.12',
            '--MAX_OPTICAL_DUPLICATE_SET_SIZE 10000',
            '--READ_NAME_REGEX null',
            '--TMP_DIR .'
        ].join(' ') }
    }

    withName: GATK4_HAPLOTYPECALLER {
        ext.args = { [
            '-ERC GVCF'
        ].join(' ') }
    }

    withName: GATK4_GENOTYPEGVCFS {
        cpus = 2
        memory = { task.attempt > 1 ? 16.GB : 12.GB }
        time = { 8.h * task.attempt }

        ext.args = { [
            '--heterozygosity 0.0001',
            '--heterozygosity-stdev 0.001'
        ].join(' ') }
    }

    withName: GATK4_GENOMICSDBIMPORT {
        cpus = 2
        memory = { task.attempt > 1 ? 16.GB : 12.GB }
        time = { 8.h * task.attempt }
    }

    withName: SELECT_ALL {
        ext.args = { [
            '--select-type-to-include SNP',
            '--exclude-filtered'
        ].join(' ') }

        ext.prefix = { [
            "${meta.id}",
            ".snps"].join('') }
    }

    withName: GATK4_VARIANTFILTRATION {
        ext.args = { [
            '--filter-expression "FS > 60.0" --filter-name "FS_gt60"',
            '--filter-expression "MQ < 40.0" --filter-name "MQ_lt40"',
            '--filter-expression "ReadPosRankSum < -8.0" --filter-name "ReadPosRankSum_ltm8"',
            '--filter-expression "MQRankSum < -12.5" --filter-name "MQRS_ltm12p5"',
            '--filter-expression "QD < 2.0" --filter-name "QD_lt2"',
            '--filter-expression "SOR > 3.0" --filter-name "SOR_gt3"'
        ].join(' ') }

        ext.prefix = { [
            "${meta.id}",
            ".snps.annotations"].join('') }
    }

        withName: SELECT_PASS {
        ext.args = { [
            '--select-type-to-include SNP',
            '--exclude-filtered'
        ].join(' ') }

        ext.prefix = { [
            "${meta.id}",
            ".snps.gatkfilters"].join('') }
    }

        withName: SELECT_BIPASS {
        ext.args = { [
            '--select-type-to-include SNP',
            '--restrict-alleles-to BIALLELIC'
        ].join(' ') }

        ext.prefix = { [
            "${meta.id}",
            ".biallelic.gatkfilters"].join('') }
    }

    // ---- VCFtools iterative filtering (single-task processes, aliased) ----
    // Gate the whole stage and keep intermediate VCFs out of the published outputs;
    // only BGZIP_TABIX (compressed products) and the reports are published.
    withName: 'VCF_.*|VCFTOOLS_DEPTH_OUTLIER|VCFTOOLS_SUMMARY' {
        ext.when   = { !params.skip_vcftools }
        cpus       = 1
        memory     = { 2.GB * task.attempt }
        publishDir = [ enabled: false ]
    }

    withName: VCF_MINDP   { ext.args = { "--min-meanDP ${params.vcf_min_meandp}" };                          ext.prefix = { 'min_meandp' } }
    withName: VCF_SITE_1  { ext.args = { "--max-missing ${params.vcf_site_missing.tokenize(',')[0]}" };       ext.prefix = { 'site_1' } }
    withName: VCF_SITE_2  { ext.args = { "--max-missing ${params.vcf_site_missing.tokenize(',')[1]}" };       ext.prefix = { 'site_2' } }
    withName: VCF_SITE_3  { ext.args = { "--max-missing ${params.vcf_site_missing.tokenize(',')[2]}" };       ext.prefix = { 'site_3' } }
    withName: VCF_RMINDV_1 { ext.args = { params.vcf_indiv_missing.tokenize(',')[0] };                        ext.prefix = { 'indiv_1' } }
    withName: VCF_RMINDV_2 { ext.args = { params.vcf_indiv_missing.tokenize(',')[1] };                        ext.prefix = { 'indiv_2' } }
    withName: VCF_RMINDV_3 { ext.args = { params.vcf_indiv_missing.tokenize(',')[2] };                        ext.prefix = { 'indiv_3' } }
    withName: VCF_FINAL   { ext.args = { "--max-missing ${params.vcf_max_missing_final}" };                  ext.prefix = { 'final_max_missing' } }

    // Product-producing aliases keep the published product names
    withName: VCF_RMFILTERED { ext.args = '--remove-filtered-all';                              ext.prefix = { "${meta.id}.filtered" } }
    withName: VCF_BIALLELIC  { ext.args = '--min-alleles 2 --max-alleles 2';                    ext.prefix = { "${meta.id}.biallelic" } }
    withName: VCF_MAC        { ext.args = { "--mac ${params.vcf_mac}" };                        ext.prefix = { "${meta.id}.biallelic.mac${params.vcf_mac}" } }
    withName: VCF_THIN       { ext.args = { "--thin ${params.vcf_thin}" };                      ext.prefix = { "${meta.id}.biallelic.mac${params.vcf_mac}.thin${params.vcf_thin}" } }
    withName: VCF_INGROUP    { ext.args = '--remove outgroups.txt --min-alleles 2 --max-alleles 2'; ext.prefix = { "${meta.id}.ingroup.biallelic" } }

    // Missingness reports + per-stage summary table -> reports/
    withName: 'VCF_RMINDV_.*' {
        publishDir = [
            path: { "${params.outdir}/vcftools/reports" },
            mode: params.publish_dir_mode,
            pattern: "*.{imiss,txt}"
        ]
    }
    withName: VCFTOOLS_SUMMARY {
        publishDir = [
            path: { "${params.outdir}/vcftools/reports" },
            mode: params.publish_dir_mode,
            pattern: "vcftools_filtering_summary.tsv"
        ]
    }

    withName: BGZIP_TABIX {
        ext.when = { !params.skip_vcftools }
        cpus     = 1
        memory   = { 2.GB * task.attempt }
        publishDir = [
            path: { "${params.outdir}/vcftools" },
            mode: params.publish_dir_mode,
            pattern: "*.vcf.gz*"
        ]
    }

    // Polyploid genotyping: intermediates (matrices, pileup, error) are not published
    withName: 'GENOTYPE_EXTRACT|SAMTOOLS_MPILEUP|GENOTYPE_ERROR' {
        publishDir = [ enabled: false ]
    }
    withName: EBG_DISEQ {
        publishDir = [
            path: { "${params.outdir}/genotyping/ebg" },
            mode: params.publish_dir_mode,
            pattern: "ebg_*.txt"
        ]
    }
    withName: UPDOG {
        publishDir = [
            path: { "${params.outdir}/genotyping/updog" },
            mode: params.publish_dir_mode,
            pattern: "updog_*.tsv"
        ]
    }
    withName: GENOTYPE_COMPARE {
        publishDir = [
            path: { "${params.outdir}/genotyping" },
            mode: params.publish_dir_mode,
            pattern: "genotype_concordance*.tsv"
        ]
    }
}

