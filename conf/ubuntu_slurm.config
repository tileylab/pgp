/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Ubuntu SLURM execution profile
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Recommended starting point for SLURM clusters on Ubuntu.
----------------------------------------------------------------------------------------
*/

params {
    config_profile_name        = 'ubuntu_slurm'
    config_profile_description = 'Ubuntu SLURM profile with scheduler-aware defaults and enhanced diagnostics'

    // Optional scheduler knobs: set at runtime, e.g.
    // --slurm_account mylab --slurm_partition short
    slurm_account          = null
    slurm_partition        = null
    slurm_cluster_options  = null
}

executor {
    name          = 'slurm'
    queueSize     = 50
    submitRateLimit = '10 sec'
    pollInterval  = '30 sec'
}

process {
    executor = 'slurm'

    clusterOptions = {
        [
            params.slurm_account ? "--account ${params.slurm_account}" : '',
            params.slurm_cluster_options ?: ''
        ].findAll { opt -> opt }.join(' ')
    }

    queue = { params.slurm_partition ?: null }

    withName: FASTP {
        cpus   = 4
        memory = { 12.GB * task.attempt }
        time   = { 8.h * task.attempt }
    }

    withName: PICARD_MARKDUPLICATES {
        cpus   = 2
        memory = { 24.GB * task.attempt }
        time   = { 12.h * task.attempt }
        maxForks = 1
    }

    withName: BWA_MEM {
        cpus   = 8
        memory = { 32.GB * task.attempt }
        time   = { 10.h * task.attempt }
    }
}

trace {
    fields = 'task_id,hash,native_id,process,tag,status,exit,attempt,cpus,memory,time,duration,realtime,%cpu,%mem,rss,vmem,workdir'
}
